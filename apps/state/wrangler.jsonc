{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "vista-state",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-12",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "HOUSEHOLD_STATE",
        "class_name": "HouseholdState"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["HouseholdState"]
    }
  ]
}
