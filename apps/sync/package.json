{
  "name": "sync",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "deploy": "wrangler deploy",
    "dev": "wrangler dev --test-scheduled --port 8788 --persist-to ../web/.wrangler/state",
    "start": "wrangler dev --test-scheduled",
