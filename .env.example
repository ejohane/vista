# Copy this file to .env.local for local development.
# scripts/dev.ts uses .env.local as the source of truth and mirrors it into
# per-worker .dev.vars files so Cloudflare local bindings can read the values.
#
# Worktree-safe startup mirrors Zine:
# - bun run dev:worktree
# - bun run dev:reset
#
# In non-main worktrees, scripts/dev.sh will symlink `.env.local` from the main
# worktree when this file is missing so secrets stay in one place.

# Clerk local development
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Plaid local development
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
# Optional for local Plaid OAuth institutions. If you use a local HTTPS proxy,
# point this at your tailnet host, for example https://vista-dev.ts.net:8443/connect/plaid.
PLAID_REDIRECT_URI=

# Base64url-encoded 32-byte key used for provider credential encryption.
PROVIDER_TOKEN_ENCRYPTION_KEY=

# Legacy provider placeholders retained for optional future work.
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=

# Optional local dev overrides
VISTA_DEV_HOST=127.0.0.1
VISTA_SKIP_SEED=0
VISTA_WEB_PORT=5173
VISTA_SYNC_PORT=8788
