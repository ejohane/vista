# Copy this file to .env.local for local development.
# scripts/dev.ts uses .env.local as the source of truth and mirrors it into
# per-worker .dev.vars files so Cloudflare local bindings can read the values.

# SnapTrade
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=

# Optional local dev overrides
VISTA_SKIP_SEED=0
VISTA_WEB_PORT=5173
VISTA_SYNC_PORT=8788
